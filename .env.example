NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
DEFAULT_ORG_ID=default-org

# Ngrok HTTPS public URL (cap nhat bang: npm run sync:ngrok)
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.dev

# PostgreSQL (chạy: npm run db:up)
DATABASE_URL="postgresql://pancake:pancake@localhost:5432/pancake?schema=public"

FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_OAUTH_REDIRECT_URI=https://your-subdomain.ngrok-free.dev/facebook-page/oauth/callback
FACEBOOK_APP_SECRET_PROOF_ENABLED=false
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your_verify_token

# Đồng bộ comment qua Graph API (fallback khi Meta không gửi webhook feed)
FEED_COMMENT_SYNC_ENABLED=true
FEED_COMMENT_SYNC_INTERVAL_MS=5000
